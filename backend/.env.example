# ─────────────────────────────────────────────────────────────
# CertVerify Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to Git.
#
# Team contacts:
#   Database setup → Jeet / Anuj
#   Backend API    → Dwij
# ─────────────────────────────────────────────────────────────

# ── Supabase PostgreSQL (Pooled connection, port 6543) ────────
# Get this from: Supabase → Project → Settings → Database → Connection string
# Use the POOLED connection on port 6543 (not 5432)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Tesseract OCR ─────────────────────────────────────────────
# Windows local dev path:
#   TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux / Docker (auto-set in Dockerfile, override if needed):
#   TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ──────────────────────────────────────────────────────
# Set to your Render/Vercel frontend URL in production
# ALLOWED_ORIGINS=https://your-frontend.onrender.com
ALLOWED_ORIGINS=*

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development
# Options: development | production
