# ─────────────────────────────────────────────────────────────
# CertVerify Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to Git.
#
# Team contacts:
#   Database setup → Jeet / Anuj
#   Backend API    → Dwij
# ─────────────────────────────────────────────────────────────

# ── MySQL / Railway Database ──────────────────────────────────
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=Local_cert_verify_db

# ── Tesseract OCR ─────────────────────────────────────────────
# Windows local dev path:
#   TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux / Docker (auto-set in Dockerfile, override if needed):
#   TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ──────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production
# ALLOWED_ORIGINS=https://cert-verify-pro.vercel.app
ALLOWED_ORIGINS=*

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development
# Options: development | production
