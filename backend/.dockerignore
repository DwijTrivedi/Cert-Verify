# Python cache — never commit these
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.venv/
.env/

# Secrets — CRITICAL: never ship these into the image
.env
*.env
secrets.json

# Local dev artifacts
*.log
*.sqlite3

# # IDE files
.vscode/
.idea/
*.swp
*.swo

# # OS junk
.DS_Store
Thumbs.db

# # Test artefacts
.pytest_cache/
htmlcov/
.coverage

# # Tesseract local install path (Windows) — not needed in Linux container
# tesseract/
# STAGE 1: Build the React Frontend
FROM node:20 AS frontend-builder
WORKDIR /app/frontend

# Point to the EXACT subfolder where package.json lives
COPY frontend/verify-trust-shine/package*.json ./
RUN npm install

# Copy everything from that subfolder and build
COPY frontend/verify-trust-shine/ ./
RUN npm run build

# STAGE 2: Build the Python Backend & Combine
FROM python:3.11-slim
WORKDIR /app

# Install system tools (The "Secret Sauce" for OCR)
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    libtesseract-dev \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy backend requirements and install
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the BUILD files from the frontend stage
# (The 'dist' folder is created inside /app/frontend during Stage 1)
COPY --from=frontend-builder /app/frontend/dist ./dist

# Copy the rest of the backend code
COPY backend/ .

# Start the engine
ENV PORT=8000
CMD gunicorn main:app --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --timeout 120
