# ────────────────────────────────────────────────────────
# CertVerify — Root .gitignore
# ────────────────────────────────────────────────────────

# ── SECRETS (CRITICAL — never commit these) ──────────────
.env
*.env
backend/.env
secrets.json
*.pem
*.key

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
htmlcov/
.coverage

# ── Node / Frontend ───────────────────────────────────────
node_modules/
frontend/verify-trust-shine/dist/
frontend/verify-trust-shine/.env.local
frontend/verify-trust-shine/.env.production
*.tsbuildinfo

# ── IDEs ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
